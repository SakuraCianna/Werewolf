# 本地 LLM 配置模板。复制为 .env 后填写真实 Key。
# 注意：VITE_ 开头的变量会进入浏览器代码，只适合个人本地测试。
# 不要把真实 Key 提交到仓库。

# 可选值：
# - openai-compatible：OpenAI Chat Completions 兼容接口
# - anthropic：Anthropic / Claude Messages 风格接口
VITE_LLM_PROVIDER=openai-compatible

# OpenAI-compatible 配置。
# 可用于 DeepSeek、OpenRouter、硅基流动、本地兼容网关等。
VITE_OPENAI_API_KEY=
VITE_OPENAI_BASE_URL=https://api.example.com
VITE_OPENAI_MODEL=your-model-name

# DeepSeek 只是可选示例，并非项目强制要求：
# VITE_OPENAI_BASE_URL=https://api.deepseek.com
# VITE_OPENAI_MODEL=deepseek-v4-flash

# Anthropic / Claude Messages 风格配置。
# 如果使用这组配置，请把 VITE_LLM_PROVIDER 改为 anthropic。
VITE_ANTHROPIC_API_KEY=
VITE_ANTHROPIC_BASE_URL=https://api.anthropic.com
VITE_ANTHROPIC_MODEL=claude-sonnet-4-5
VITE_ANTHROPIC_VERSION=2023-06-01
