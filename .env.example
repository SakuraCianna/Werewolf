# 本地 LLM 配置模板。复制为 .env 后填写真实 Key。
# 注意：VITE_ 开头的变量会进入浏览器代码，只适合个人本地测试。

# 当前默认使用 OpenAI-compatible 接口。DeepSeek V4 的 OpenAI 格式 Base URL 仍是 https://api.deepseek.com。
VITE_LLM_PROVIDER=openai-compatible

# DeepSeek API Key。不要把真实 Key 提交到仓库。
VITE_OPENAI_API_KEY=

# DeepSeek OpenAI-compatible Base URL。
VITE_OPENAI_BASE_URL=https://api.deepseek.com

# 本项目当前用于 DeepSeek 测试的模型。
VITE_OPENAI_MODEL=deepseek-v4-flash

# chat 表示使用 Chat Completions 风格的请求格式。
VITE_OPENAI_API_STYLE=chat

# 如果后续想用 DeepSeek 的 Anthropic-compatible 格式，再把 VITE_LLM_PROVIDER 改为 anthropic 并填写下面几项。
VITE_ANTHROPIC_API_KEY=
VITE_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
VITE_ANTHROPIC_MODEL=deepseek-v4-flash
VITE_ANTHROPIC_VERSION=2023-06-01
